{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "title",
    "authors",
    "publication",
    "keywords"
  ],
  "additionalProperties": true,
  "properties": {
    "title": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": [
          "name",
          "affiliation"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "affiliation": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "publication": {
      "type": "object",
      "required": [
        "year"
      ],
      "properties": {
        "year": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}